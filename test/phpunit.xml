    beStrictAboutOutputDuringTests="true"
    executionOrder="random"
    colors="true"
>
    <extensions>
        <bootstrap class="ScriptFUSION\Pip\PipExtension"/>
    </extensions>

    <testsuite name="default">
        <directory>.</directory>
    </testsuite>
    <source>
        <include>
            <directory>../src</directory>
        </include>
    </source>
</phpunit>
